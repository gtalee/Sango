<!--  权限
	0x0001: shutdown 关闭服务器的权限
	0x0002: addip 增加信任IP的权限,已经过期.由于开放IP并且增加代理,此功能不再有效
	0x0004: reload 重载诸如关卡数据的权限
	0x0008: delete 删除
	0x0010: modifyaccount 修改帐号信息
	0x0020: modify 修改数值
	0x0040: add 增加虚拟物品
	0x0080: move 移动玩家坐标
	0x0100: public long forbidaccount  = 1L << 8;
	0x0200: public long forbid         = 1L << 9;
	0x0400: kick           = 1L << 10;
	0x0800: mute           = 1L << 11;
	0x1000: releaseaccount = 1L << 12;
	0x2000: accountinfo    = 1L << 13;
	0x4000: show           = 1L << 14;
	0x8000: who            = 1L << 15;
	0x00010000: maxplayer      = 1L << 16;
	0x00020000: netbattle      = 1L << 17; // 
	0x00040000: overhear       = 1L << 18; // 侦听帮派,小队等聊天频道的权限
	0x00080000: chat           = 1L << 19; // 聊天的权限
	0x00100000: brocast        = 1L << 20; // 广播的权限
	0x00200000: root        = 1L << 21; // 根权限,创建GM帐号,修改GM权限的权限
	0x00400000: tongbattle        = 1L << 22; // 调整帮派战斗的权限
	0x00800000: loginmsg    = 1L << 23;  // 修改登录消息的权限
	0x01000000: deleteGmMail         = 1L << 24; // 是否有权限通过GM借口删除玩家呼叫GM的内容
	0x02000000: regulateExp = 1L << 25;// 调整全服打怪经验倍数的权力。（幻想中暂时没实现）
	0x04000000: traceAdmin         = 1L << 26; // 是否有权限跟踪其他ＧＭ活动
 -->
