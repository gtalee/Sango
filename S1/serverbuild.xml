<project name="Sanguo1.0" default="dist" basedir=".">
	<property name="db" location="${db.dir}/src" />
	<!--property name="net" location="${net.dir}/src" /-->
	<property name="editor" location="${editor.dir}/src" />
	<property name="workshop" location="${workshop.dir}/src" />
	<property name="server" location="${server.dir}/src" />
	<property name="partner" location="${partner.dir}/src" />
	<property name="build" location="build" />
	<property name="dist" location="dist" />
	<path id="libs">
		<fileset dir="lib">
			<include name="**/*.jar" />
		</fileset>
		<fileset dir="${eclipsehome}/plugins">
			<include name="**/org.eclipse*.jar" />
		</fileset>
		<fileset dir="${editor.dir}/lib">
			<include name="**/*.jar" />
		</fileset>
		<!--fileset dir="${net.dir}/lib">
			<include name="**/*.jar" />
		</fileset-->
		<fileset dir="${db.dir}/lib">
			<include name="**/*.jar" />
		</fileset>
	</path>
	<target name="init">
		<mkdir dir="${build}" />
	</target>

	<target name="compiledb" depends="init">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${db}" />
		</javac>
	</target>

	<!--target name="compilenet" depends="init">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${net}" />
		</javac>
	</target-->

	<target name="compileeditor" depends="init">
		<javac nowarn="true" destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${editor}" />
		</javac>
		<taskdef name="generate" classname="com.pip.sanguo.data.ant.GenerateSkillAndBuff" classpath="${build}" classpathref="libs" />
		<taskdef name="buildfileversion" classname="com.pip.sanguo.data.ant.BuildFileVersion" classpath="${build}" classpathref="libs" />
	</target>

	<target name="compileworkshop" depends="init">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${workshop}" />
		</javac>
	</target>

	<target name="compileserver" depends="compiledb,compileeditor,compileworkshop,compilepartner,generateskillandbuff,buildfileversion">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${server}" />
		</javac>
	</target>
	
	<target name="compilepartner" depends="init">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="UTF-8">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${partner}" />
		</javac>
	</target>


	<target name="disteditor" depends="compileeditor">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/editor.jar">
			<fileset dir="${build}" includes="**/com/pip/sanguo/**" />
		</jar>
	</target>

	<target name="generateskillandbuff" depends="compileeditor">
		<generate source="${data.dir}" target="${server}" />
		<generate source="${data.dir}" target="${server}" />
	</target>

	<target name="buildfileversion" depends="compileeditor">
		<buildfileversion source="${data.dir}" />
	</target>


	<target name="distdb" depends="compiledb">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/db.jar">
			<fileset dir="${build}" includes="**/com/pip/db/**" />
		</jar>
	</target>

	<!--target name="distnet" depends="compilenet">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/commonnet.jar">
			<fileset dir="${build}" includes="**/com/pip/net/**" />
		</jar>
	</target-->

	<target name="distworkshop" depends="compileworkshop">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/workshop.jar">
			<fileset dir="${build}" includes="**/com/pip/**" />
			<fileset dir="${build}" includes="**/com/pipimage/**" />
			<fileset dir="${build}" includes="**/com/jcraft/**" />
		</jar>
	</target>
	
	<target name="distpartner" depends="compilepartner">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/partner.jar">
			<fileset dir="${build}" includes="**/com/pip/partner/**" />
		</jar>
	</target>

	<target name="distskills" depends="compileserver">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/skill.jar">
			<fileset dir="${build}">
				<include name="**/peony/game/skill/AutoGenerated*" />
				<include name="**/peony/game/buff/AutoGenerated*" />
			</fileset>
		</jar>
	</target>

	<target name="distserver" depends="compileserver">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/peony.jar">
			<fileset dir="${build}">
				<include name="**/peony/**" />
				<exclude name="**/peony/game/skill/AutoGenerated*" />
				<exclude name="**/peony/game/buff/AutoGenerated*" />
			</fileset>
		</jar>
	</target>

	<target name="commit" depends="distserver">
		<cvs cvsRoot="${cvsroot4}" dest="src" command="update -R" />
		<cvs cvsRoot="${cvsroot4}" dest="src" command="commit -m ${commit.time}" />
		<cvs cvsRoot="${cvsroot4}" command="commit -m ${commit.time} ../data/fileversion.xml" />
		<cvs cvsRoot="${cvsroot4}" command="commit -m ${commit.time} ../data/Skill/skills.xml" />
		<cvs cvsRoot="${cvsroot4}" command="commit -m ${commit.time} ../data/Skill/buffs.xml" />
		<cvs cvsRoot="${cvsroot4}" command="commit -m ${commit.time} ../data/client_pkg" />
		<cvs cvsRoot="${cvsroot4}" command="commit -m ${commit.time} ../data/scripts" />
	</target>

	<target name="dist" depends="clean,distdb,distworkshop,distpartner,disteditor,distserver,distskills,commit" />

	<target name="clean" description="clean up">
		<delete dir="${build}" />
		<delete dir="${dist}" />
	</target>

</project>