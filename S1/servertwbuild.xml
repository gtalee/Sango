<project name="Sanguo1.0" default="dist" basedir=".">
	<property name="db" location="${db.dir}/src" />
	<property name="net" location="${net.dir}/src" />
	<property name="editor" location="${editor.dir}/src" />
	<property name="workshop" location="${workshop.dir}/src" />
	<property name="server" location="${server.dir}/src" />
	<property name="build" location="build" />
	<property name="dist" location="dist" />
	<path id="libs">
		<fileset dir="lib">
			<include name="**/*.jar" />
		</fileset>
		<fileset dir="${eclipsehome}/plugins">
			<include name="**/org.eclipse*.jar" />
		</fileset>
		<fileset dir="${editor.dir}/lib">
			<include name="**/*.jar" />
		</fileset>
		<fileset dir="${net.dir}/lib">
			<include name="**/*.jar" />
		</fileset>
		<fileset dir="${db.dir}/lib">
			<include name="**/*.jar" />
		</fileset>
	</path>
	<target name="init">
		<mkdir dir="${build}" />
	</target>

	<target name="compiledb" depends="init">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${db}" />
		</javac>
	</target>

	<target name="compilenet" depends="init">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${net}" />
		</javac>
	</target>

	<target name="compileeditor" depends="init">
		<javac nowarn="true" destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${editor}" />
		</javac>
		<copydir src="${editor}" dest="build" includes="**/*.data"/>
		<taskdef name="datecatalog" classname="com.pip.sanguo.data.ant.DateCatalog" classpath="${build}" classpathref="libs" />
		<taskdef name="dealsevercode" classname="com.pip.sanguo.data.ant.DealSeverCode" classpath="${build}" classpathref="libs" />
		<taskdef name="generatecomplexskillandbuff" classname="com.pip.sanguo.data.ant.GenerateComplexSkillAndBuff" classpath="${build}" classpathref="libs" />
		<taskdef name="buildcomplexfileversion" classname="com.pip.sanguo.data.ant.BuildComplexFileVersion" classpath="${build}" classpathref="libs" />

	</target>

	<target name="compileworkshop" depends="init">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${workshop}" />
		</javac>
	</target>

	<target name="compileserver" depends="compilenet,compiledb,compileeditor,compileworkshop,datecatalog,dealsevercode,generatecomplexskillandbuff,buildcomplexfileversion">
		<javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="utf8">
			<classpath>
				<path refid="libs" />
				<pathelement path="${build}" />
			</classpath>
			<src path="${server}" />
		</javac>
	</target>


	<target name="disteditor" depends="compileeditor">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/editor.jar">
			<fileset dir="${build}" includes="**/com/pip/sanguo/**" />
		</jar>
	</target>
	<target name="buildcomplexfileversion" depends="commitdata">
		<buildcomplexfileversion source="${datatw.dir}/data" />
	</target>
	<target name="datecatalog" depends="compileeditor">
		<datecatalog source="${data.dir}" />
	</target>
	<target name="dealsevercode" depends="compileeditor">
		<dealsevercode source="${data.dir}" target="${server}"/>
	</target>
	<target name="generatecomplexskillandbuff" depends="compileeditor">
		<generatecomplexskillandbuff source="${datatw.dir}/data" target="${server}"/>
	</target>
	<target name="distdb" depends="compiledb">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/db.jar">
			<fileset dir="${build}" includes="**/com/pip/db/**" />
		</jar>
	</target>

	<target name="distnet" depends="compilenet">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/commonnet.jar">
			<fileset dir="${build}" includes="**/com/pip/net/**" />
		</jar>
	</target>

	<target name="distworkshop" depends="compileworkshop">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/workshop.jar">
			<fileset dir="${build}" includes="**/com/pip/**" />
			<fileset dir="${build}" includes="**/com/pipimage/**" />
			<fileset dir="${build}" includes="**/com/jcraft/**" />
		</jar>
	</target>

	<target name="distskills" depends="compileserver">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/skill.jar">
			<fileset dir="${build}">
				<include name="**/peony/game/skill/AutoGenerated*" />
				<include name="**/peony/game/buff/AutoGenerated*" />
			</fileset>
		</jar>
	</target>

	<target name="distserver" depends="compileserver">
		<mkdir dir="${dist}" />
		<jar destfile="${dist}/peony.jar">
			<fileset dir="${build}">
				<include name="**/peony/**" />
				<exclude name="**/peony/game/skill/AutoGenerated*" />
				<exclude name="**/peony/game/buff/AutoGenerated*" />
			</fileset>
		</jar>
	</target>

	<target name="commit" depends="distserver">
		<cvs cvsRoot="${cvsroot4}" command="commit -m ${commit.time} ../data_zh_TW/data/fileversion.xml" />
		<cvs cvsRoot="${cvsroot4}" command="commit -R -m ${commit.time} ../data_zh_TW/data/client_pkg" />
		<cvs cvsRoot="${cvsroot4}" command="commit -R -m ${commit.time} ../data_zh_TW/data/scripts" />
	</target>
	
	<target name="commitdata" depends="datecatalog">
		<cvs cvsRoot="${cvsroot4}" command="commit -R ../data_zh_TW/data" />
	</target>

	<target name="dist" depends="clean,distdb,distnet,distworkshop,disteditor,distserver,distskills,commit" />

	<target name="clean" description="clean up">
		<delete dir="${build}" />
		<delete dir="${dist}" />
	</target>

</project>