<?xml version="1.0"?>
<project name="sango" basedir="." default="">
    <property file="custom.properties"/>
    <property name="cvsroot3" value=":pserver:${cvsuser}:${cvspass}@192.168.0.3:/repository"/>
    <property name="cvsroot4" value=":pserver:${cvsuser}:${cvspass}@192.168.0.4:/repository"/>
    <property name="server.dir" value="server"/>
    <property name="editor.dir" value="editor"/>
    <property name="db.dir" value="db"/>
    <property name="net.dir" value="net"/>
    <property name="data.dir" value="data"/>
    <property name="data.locale.dir" value="data_${locale}"/>
    <property name="workshop.dir" value="workshop"/>
    <property name="server.module.name" value="projects/sanguo1.0/Sango1.0-Server"/>
    <property name="editor.module.name" value="projects/sanguo1.0/Sanguo-Editor1.0"/>
    <property name="db.module.name" value="projects/sanguo1.0/db"/>
    <property name="workshop.module.name" value="library/ImageWorkshop1.0"/>
    <property name="data.module.name" value="projects/sanguo1.0/Sanguo1.0-Data"/>
    <property name="db" value="${basedir}/${db.dir}/src" />
    <property name="editor" value="${basedir}/${editor.dir}/src" />
    <property name="workshop" value="${basedir}/${workshop.dir}/src" />
    <property name="server" value="${basedir}/${server.dir}/src" />
    <property name="build" value="build" />
    <property name="dist" value="dist" />
  
    <path id="libs">
        <fileset dir="${basedir}/${server.dir}/lib">
            <include name="**/*.jar" />
        </fileset>
        <fileset dir="${eclipsehome}/plugins">
            <include name="**/org.eclipse*.jar" />
        </fileset>
        <fileset dir="${basedir}/${editor.dir}/lib">
            <include name="**/*.jar" />
        </fileset>
        <fileset dir="${basedir}/${db.dir}/lib">
            <include name="**/*.jar" />
        </fileset>
    </path>
    
    <!--########## Compile ##########-->
    <target name="init">
        <mkdir dir="${build}" />
    </target>

    <target name="compiledb" depends="init">
        <javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
            <classpath>
                <path refid="libs" />
                <pathelement path="${build}" />
            </classpath>
            <src path="${db}" />
        </javac>
    </target>

    <target name="compileeditor" depends="init,compileworkshop">
        <javac nowarn="true" destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
            <classpath>
                <path refid="libs" />
                <pathelement path="${build}" />
            </classpath>
            <src path="${editor}" />
        </javac>
        <copydir src="${editor}" dest="build" includes="**/*.data"/>
    </target>
    
    <target name="compileworkshop" depends="init">
        <javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="GBK">
            <classpath>
                <path refid="libs" />
                <pathelement path="${build}" />
            </classpath>
            <src path="${workshop}" />
        </javac>
    </target>

    <target name="compileserver" depends="compiledb, compileworkshop, compileeditor, locale.code, locale.skillbuff">
        <javac destdir="${build}" debug="true" source="1.5" target="1.5" encoding="utf8">
            <classpath>
                <path refid="libs" />
                <pathelement path="${build}" />
            </classpath>
            <src path="${server}" />
        </javac>
    </target>
    <!--########## Compile End ##########-->

    <!--########## Dist ##########-->
    <target name="distdb" depends="compiledb">
        <mkdir dir="${dist}" />
        <jar destfile="${dist}/db.jar">
            <fileset dir="${build}" includes="**/com/pip/db/**" />
        </jar>
    </target>

    <target name="distworkshop" depends="compileworkshop">
        <mkdir dir="${dist}" />
        <jar destfile="${dist}/workshop.jar">
            <fileset dir="${build}" includes="**/com/pip/**" />
            <fileset dir="${build}" includes="**/com/pipimage/**" />
            <fileset dir="${build}" includes="**/com/jcraft/**" />
        </jar>
    </target>
    
    <target name="disteditor" depends="compileeditor">
        <mkdir dir="${dist}" />
        <jar destfile="${dist}/editor.jar">
            <fileset dir="${build}" includes="**/com/pip/sanguo/**" />
        </jar>
    </target>
    
    <target name="distskills" depends="compileserver">
        <mkdir dir="${dist}" />
        <jar destfile="${dist}/skill.jar">
            <fileset dir="${build}">
                <include name="**/peony/game/skill/AutoGenerated*" />
                <include name="**/peony/game/buff/AutoGenerated*" />
            </fileset>
        </jar>
    </target>
    
    <target name="distserver" depends="compileserver">
        <mkdir dir="${dist}" />
        <jar destfile="${dist}/peony.jar">
            <fileset dir="${build}">
                <include name="**/peony/**" />
                <exclude name="**/peony/game/skill/AutoGenerated*" />
                <exclude name="**/peony/game/buff/AutoGenerated*" />
            </fileset>
        </jar>
    </target>
    <!--########## Dist End ##########-->

    <!--########## Locales Process ##########-->
    <target name="locale.data" depends="compileeditor">
        <taskdef name="locale.data" classname="com.pip.sanguo.data.ant.DateCatalog" classpath="${build}" classpathref="libs" />
        <locale.data source="${basedir}/${data.dir}" localeID="${locale}"/>
    </target>
    
    <target name="locale.fileversion" depends="">
        <taskdef name="locale.fileversion" classname="com.pip.sanguo.data.ant.BuildComplexFileVersion" classpath="${build}" classpathref="libs" />
        <locale.fileversion source="${basedir}/${data.locale.dir}/data"/>
    </target>
    
    <target name="locale.code" depends="compileeditor">
        <taskdef name="locale.code" classname="com.pip.sanguo.data.ant.DealSeverCode" classpath="${build}" classpathref="libs" />
        <locale.code source="${basedir}/${data.dir}" target="${server}" localeID="${locale}"/>
    </target>
    
    <target name="locale.skillbuff" depends="compileeditor">
        <taskdef name="locale.skillbuff" classname="com.pip.sanguo.data.ant.GenerateComplexSkillAndBuff" classpath="${build}" classpathref="libs" />
        <locale.skillbuff source="${basedir}/${data.locale.dir}/data" target="${server}"/>
    </target>
    <!--########## Locales Process End ##########-->

    <!--########## CVS ##########-->
    <target name="checkout-server" depends="">   
        <delete dir="${basedir}/${server.dir}"/>    
        <cvs cvsRoot="${cvsroot4}" package="${server.module.name}" command="checkout -P -d ./${server.dir} -r ${server.tag}"/> 
    </target>

    <target name="checkout-editor" depends="">   
        <delete dir="${basedir}/${editor.dir}"/>    
        <cvs cvsRoot="${cvsroot4}" package="${editor.module.name}" command="checkout -P -d ./${editor.dir} -r ${editor.tag}"/>   
    </target>
    
    <target name="checkout-db" depends="">   
        <delete dir="${basedir}/${db.dir}"/>    
        <cvs cvsRoot="${cvsroot4}" package="${db.module.name}" command="checkout -P -d ./${db.dir} -r ${db.tag}"/>   
    </target>

    <target name="checkout-workshop" depends="">   
        <delete dir="${basedir}/${workshop.dir}"/>    
        <cvs cvsRoot="${cvsroot3}" package="${workshop.module.name}" command="checkout -P -d ./${workshop.dir} -r ${workshop.tag}"/>   
    </target> 
    
    <target name="checkout-data" depends="">   
        <delete dir="${basedir}/${data.dir}"/>
        <delete dir="${basedir}/${data.locale.dir}"/>
        <mkdir dir="${basedir}/${data.dir}"/>
        <mkdir dir="${basedir}/${data.locale.dir}"/>
        <cvs cvsRoot="${cvsroot4}" package="${data.module.name}/data" command="checkout -P -d ./${data.dir} -r ${data.tag}"/>
        <cvs cvsRoot="${cvsroot4}" package="${data.module.name}/data_${locale}" command="checkout -P -d ./${data.locale.dir}"/>
    </target>
    
    <tstamp>
        <format property="date.now" pattern="yyyyMMdd" locale="en" />
    </tstamp>
    
    <target name="commit" depends="">
        <echo>
            Updating ...
        </echo>
        <cvs cvsRoot="${cvsroot4}" dest="${data.locale.dir}" command="update -R"/>
        <echo>
            commiting ...
        </echo>
        <cvs cvsRoot="${cvsroot4}" dest="${data.locale.dir}" command="commit -m 'Autocommit_${date.now}'"/>
    </target>
    <!--########## CVS End ##########-->

    <!--########## Remote Action ##########-->
    <target name="remote-deploy">
        <scp todir="${remote.server.username}@${remote.server.ip}:${remote.server.basedir}" password="${remote.server.password}" trust="true" verbose="true">
            <fileset dir="${basedir}/${dist}">
                <include name="skill.jar"/>
                <include name="data.7z"/>
            </fileset>
        </scp>
        <scp todir="${remote.server.username}@${remote.server.ip}:${remote.server.libdir}" password="${remote.server.password}" trust="true" verbose="true">
            <fileset dir="${basedir}/${dist}">
                <include name="peony.jar"/>
                <include name="commonnet.jar"/>
                <include name="workshop.jar"/>
                <include name="db.jar"/>
                <include name="editor.jar"/>
            </fileset>
        </scp>
    </target>

    <target name="remote-udata">
        <sshexec host="${remote.server.ip}" username="${remote.server.username}" password="${remote.server.password}" trust="true" command="${remote.server.basedir}/udata"/>
    </target>

    <target name="remote-restart">
        <sshexec host="${remote.server.ip}" username="${remote.server.username}" password="${remote.server.password}" trust="true" command="${remote.server.basedir}/kserver"/>
        <sshexec host="${remote.server.ip}" username="${remote.server.username}" password="${remote.server.password}" trust="true" command="cd ${remote.server.basedir};./startup_silent.sh"/>
    </target>
    
    <target name="remote-deploy2">
        <scp todir="${remote.server.username2}@${remote.server.ip2}:${remote.server.basedir2}" password="${remote.server.password2}" trust="true" verbose="true">
            <fileset dir="${basedir}/${dist}">
                <include name="skill.jar"/>
                <include name="data.7z"/>
            </fileset>
        </scp>
        <scp todir="${remote.server.username2}@${remote.server.ip2}:${remote.server.libdir2}" password="${remote.server.password2}" trust="true" verbose="true">
            <fileset dir="${basedir}/${dist}">
                <include name="peony.jar"/>
                <include name="commonnet.jar"/>
                <include name="workshop.jar"/>
                <include name="db.jar"/>
                <include name="editor.jar"/>
            </fileset>
        </scp>
    </target>

    <target name="remote-udata2">
        <sshexec host="${remote.server.ip2}" username="${remote.server.username2}" password="${remote.server.password2}" trust="true" command="${remote.server.basedir2}/udata"/>
    </target>

    <target name="remote-restart2">
        <sshexec host="${remote.server.ip2}" username="${remote.server.username2}" password="${remote.server.password2}" trust="true" command="${remote.server.basedir2}/kserver"/>
        <sshexec host="${remote.server.ip2}" username="${remote.server.username2}" password="${remote.server.password2}" trust="true" command="cd ${remote.server.basedir2};./startup_silent.sh"/>
    </target>
    <!--########## Remote Action End ##########-->

    <target name="7z" depends="">
        <mkdir dir="${basedir}/${dist}" />
        <exec executable="${7z}" >
            <arg line="a -m0=BCJ2 -m1=LZMA:d23 -m2=LZMA:d19 -m3=LZMA:d19 -mb0:1 -mb0s1:2 -mb0s2:3 ${basedir}/${dist}/data.7z ${basedir}/${data.locale.dir}/data"/>
        </exec>
    </target>      

    <target name="clean-code" description="clean code">
        <delete dir="${basedir}/${server.dir}" />
        <delete dir="${basedir}/${editor.dir}" />
        <delete dir="${basedir}/${workshop.dir}" />
        <delete dir="${basedir}/${db.dir}" />
        <delete dir="${basedir}/${build}" />
    </target>

    <target name="clean-dist" description="clean dist">
        <delete dir="${basedir}/${dist}" />
    </target>
    
    <target name="clean-data" description="clean data">
        <delete dir="${basedir}/${data.dir}" />
        <delete dir="${basedir}/${data.locale.dir}" />
    </target>
    
    <target name="dist-code" depends="distdb, distworkshop, disteditor, distserver, distskills">
        <copy file="${basedir}/${server.dir}/lib/commonnet.jar" todir="${basedir}/${dist}" />
    </target>
    
    <target name="dist-data" depends="">
        <antcall target="locale.data" />
        <antcall target="commit" />
        <antcall target="locale.fileversion" />
        <antcall target="commit" />
    </target>

    <target name="build-checkout">
        <antcall target="build-checkout-code" />
        <antcall target="build-checkout-data" />
    </target>
    
    <target name="build-checkout-code">
        <antcall target="clean-code" />
        <antcall target="checkout-server" />
        <antcall target="checkout-editor" />  
        <antcall target="checkout-db" />  
        <antcall target="checkout-workshop" />
    </target>
    
    <target name="build-checkout-data">
        <antcall target="clean-data" /> 
        <antcall target="checkout-data" />
    </target>
    
    <target name="build">
        <antcall target="build-checkout" />
        <antcall target="clean-dist" />
        <antcall target="dist-data" />
        <antcall target="dist-code" />
        <antcall target="commit" />
        <antcall target="7z" />
    </target>
    
    <target name="build-code">
        <antcall target="build-checkout-code" />
        <antcall target="dist-code" /> 
    </target>
</project>